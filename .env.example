# .env.example - Copy this file to .env and fill in your values.
# NEVER commit your actual .env to version control.

# Your Discord Bot Token from https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token_here

# The ID of the Discord channel where contest notifications will be sent.
NOTIFICATION_CHANNEL_ID=your_channel_id_here

# Optional: Role IDs to ping when a specific division contest is coming.
# Leave blank to disable pings for that division.
ROLE_DIV1=
ROLE_DIV2=
ROLE_DIV3=
ROLE_DIV4=
ROLE_EDUCATIONAL=
ROLE_GLOBAL=
ROLE_OTHER=

# How many minutes BEFORE a contest the bot sends the first warning (default: 60).
NOTIFY_BEFORE_MINUTES=60

# How often (in minutes) the background loop polls the Codeforces API (default: 10).
POLL_INTERVAL_MINUTES=10
